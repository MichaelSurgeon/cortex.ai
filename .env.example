# Required — OpenAI API key for GPT-4o-mini processing
OPENAI_API_KEY=sk-...

# Required — GetX API key for X/Twitter posts (https://getxapi.com)
GETX_API_KEY=...

# Optional — URL the Streamlit frontend uses to reach the backend
API_BASE_URL=http://localhost:8000/api/v1

# Optional — CORS origin allowed to call the backend (must match where Streamlit runs)
ALLOWED_ORIGINS=http://localhost:8501
